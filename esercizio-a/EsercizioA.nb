Cell[CellGroupData[{

Cell["\<\
Calcolo la risposta libera sfruttando la decomposizione modale\
\>", "Subsection",
 CellChangeTimes->{
  3.9240876240193596`*^9},ExpressionUUID->"c536b3f6-e509-e642-a0f8-\
5ca17e5de735"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["x", "l"], "[", "t_", "]"}], ":=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"T", ".", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"\[Lambda]", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "t"}], "]"}], "0", "0", "0"},
         {"0", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"\[Lambda]", "[", 
             RowBox[{"[", "2", "]"}], "]"}], "t"}], "]"}], "0", "0"},
         {"0", "0", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"\[Sigma]", " ", "t"}], "]"}], 
           RowBox[{"Cos", "[", 
            RowBox[{"\[Omega]", " ", "t"}], "]"}]}], 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"\[Sigma]", " ", "t"}], "]"}], 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Omega]", " ", "t"}], "]"}]}]},
         {"0", "0", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Exp", "[", 
             RowBox[{"\[Sigma]", " ", "t"}], "]"}]}], 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Omega]", " ", "t"}], "]"}]}], 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"\[Sigma]", " ", "t"}], "]"}], 
           RowBox[{"Cos", "[", 
            RowBox[{"\[Omega]", " ", "t"}], "]"}]}]}
        }], "\[NoBreak]", ")"}], ".", 
      SubscriptBox["z", "0"]}], "]"}]}], ";"}], "*)"}]], "Input",
 CellChangeTimes->{
  3.9240876397797184`*^9, {3.924087855792586*^9, 3.924087917595703*^9}, {
   3.924091331497978*^9, 3.924091339753235*^9}, {3.924091753170906*^9, 
   3.924091788081114*^9}, 3.92424723001614*^9, {3.924250767781763*^9, 
   3.9242507813357735`*^9}, {3.925719097696785*^9, 3.9257191103643284`*^9}, {
   3.929757238461195*^9, 3.929757242640616*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"36744285-77ef-904f-9f5c-afb030e75ecc"],

