  RowBox[{
   SubscriptBox["Q", "1"], "=", 
   RowBox[{
    UnderscriptBox["\[Limit]", 
     RowBox[{"s", "\[Rule]", 
      RowBox[{"-", "3"}]}]], 
    RowBox[{
     RowBox[{"(", 
